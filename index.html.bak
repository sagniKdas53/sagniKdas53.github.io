<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="stylesheet" href="style.css">
    
    <title>Tests</title>
  </head>
  <body style="background-color: white;">
    <p style="margin-left: 80px; text-align: left; background-color: white;"><span
        style="font-family: sans-serif;">Timer: 00</span></p>
    <p id="left" style="margin-left: 80px; text-align: left; background-color: white;"><span
        style="font-family: sans-serif;">Energy will fill up at: 00<br>
      </span></p>
    <p style="margin-left: 80px; text-align: left; background-color: white;"><span
        style="font-family: sans-serif;">&nbsp;&nbsp;&nbsp; Max
        Energy:&nbsp;&nbsp; &nbsp;&nbsp;&nbsp; &nbsp;&nbsp; &nbsp;
        &nbsp;&nbsp;&nbsp; <input id="max" type="text"> <br>
      </span></p>
    <p style="margin-left: 80px; text-align: left; background-color: white;"><span
        style="font-family: sans-serif;">&nbsp;&nbsp;&nbsp; Current
        Energy:&nbsp;&nbsp; &nbsp;&nbsp; &nbsp;&nbsp;&nbsp; <input id="ce" type="text">
        <br>
      </span></p>
    <p style="margin-left: 80px; text-align: left; background-color: white;"><span
        style="font-family: sans-serif;">&nbsp;&nbsp;&nbsp; Minutes per
        Energy:&nbsp;&nbsp;&nbsp; </span><span style="font-family: sans-serif;"><input
          id="mpe" type="text"></span> </p>
    <blockquote style="background-color: white;">
      <div class="bb" style="margin-left: 80px; text-align: left">
        <span style="font-family: sans-serif;"><button onclick="compute()">Calculate</button>
          <button onclick="set()">Load from Cookies</button></span>
      </div>
    </blockquote>
    <div style="margin-left: 80px; text-align: left; background-color: white;">
    </div>
    <div style="margin-left: 80px; text-align: left; background-color: white;"><span
        style="font-family: sans-serif;">
      <script src="script.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/js-cookie@rc/dist/js.cookie.min.js"></script>
        <script type="text/javascript">set();</script></span></div>
    <span style="font-family: sans-serif;"> </span>
  </body>
</html>
